# Caddy reverse proxy cho HungSilver — HTTPS qua Cloudflare (proxy BẬT).
#   Trình duyệt  <->  Cloudflare : cert edge của Cloudflare (tự động, Universal SSL).
#   Cloudflare   <->  origin/Caddy : Cloudflare Origin Certificate (mount ở ./certs).
# Yêu cầu: đặt SSL/TLS mode = "Full (strict)" trên Cloudflare.
#
# (Nếu sau này TẮT proxy Cloudflare — DNS only, trỏ thẳng VPS — thì thay khối tls
#  bên dưới bằng global "{ email ban@email }" để Caddy tự xin Let's Encrypt.)
h-edutech.io.vn {
	tls /etc/caddy/certs/origin-cert.pem /etc/caddy/certs/origin-key.pem
	encode gzip zstd
	# Proxy toàn bộ sang container client (nginx). nginx tự xử /api -> api:8080.
	reverse_proxy client:80
}
