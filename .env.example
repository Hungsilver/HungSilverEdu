# Copy file này thành .env rồi đổi giá trị trước khi `docker compose up`.
# KHÔNG commit file .env.

# Mật khẩu database PostgreSQL
POSTGRES_PASSWORD=doi-mat-khau-nay

# Khóa ký JWT — BẮT BUỘC đổi, tối thiểu 32 ký tự ngẫu nhiên
# Gợi ý tạo: PowerShell -> -join ((48..57)+(97..122) | Get-Random -Count 64 | % {[char]$_})
JWT_SECRET=doi-khoa-nay-thanh-chuoi-ngau-nhien-toi-thieu-32-ky-tu

# Google OAuth Client ID (Web application) — để trống nếu chưa dùng Google Login
GOOGLE_CLIENT_ID=

# Tài khoản admin KHÔNG auto-seed — tạo thủ công khi cần
# (mặc định admin / Admin@a1, đổi ngay sau khi đăng nhập lần đầu).

# Cổng HTTP công khai của client (nginx)
HTTP_PORT=80

# --- Chỉ dùng cho docker-compose.prod.yml (kéo image từ GHCR, đặt .env này trên VPS) ---
# GHCR_OWNER = tên owner GitHub viết THƯỜNG (vd: hungsilver)
GHCR_OWNER=hungsilver
# Tag image cần chạy (mặc định CD đẩy lên tag "latest")
IMAGE_TAG=latest
